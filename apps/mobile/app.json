{
  "expo": {
    "name": "Bin",
    "slug": "bin",
    "scheme": "bin",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "android": {
      "package": "com.yourcompany.bin",
      "permissions": ["RECORD_AUDIO"]
    },
    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": "Allow Bin to record voice captures."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
