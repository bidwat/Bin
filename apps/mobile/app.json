{
  "expo": {
    "name": "Bin",
    "slug": "bin",
    "scheme": "bin",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "android": {
      "package": "com.yourcompany.bin",
      "permissions": ["RECORD_AUDIO", "CAMERA", "POST_NOTIFICATIONS"]
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-av",
        {
          "microphonePermission": "Allow Bin to record voice captures."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Bin to import images into your feed.",
          "cameraPermission": "Allow Bin to capture photos into your feed."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
